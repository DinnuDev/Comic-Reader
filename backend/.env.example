PORT=3001
NODE_ENV=development

# Session secret - change this in production
SESSION_SECRET=comic-reader-secret-change-me

# Database path
DB_PATH=./data/comic-reader.db

# Upload/Cache directory
CACHE_DIR=./data/cache
COVERS_DIR=./data/covers

# Google Drive OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gdrive/callback

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated additional frontend origins
# FRONTEND_URLS=http://localhost:5173,https://your-app.onrender.com

# Optional default admin seed (created only if account does not exist)
DEFAULT_ADMIN_EMAIL=ops.curator@comixhq.io
DEFAULT_ADMIN_USERNAME=vault.curator
DEFAULT_ADMIN_PASSWORD=R7!mQ2#Lx9@T
